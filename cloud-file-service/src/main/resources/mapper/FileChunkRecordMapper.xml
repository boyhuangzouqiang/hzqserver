<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hzqserver.file.mapper.FileChunkRecordMapper">

    <resultMap id="BaseResultMap" type="com.hzqserver.file.entity.FileChunkRecord">
        <id column="id" property="id"/>
        <result column="file_md5" property="fileMd5"/>
        <result column="chunk_index" property="chunkIndex"/>
        <result column="chunk_md5" property="chunkMd5"/>
        <result column="chunk_size" property="chunkSize"/>
        <result column="storage_path" property="storagePath"/>
        <result column="upload_time" property="uploadTime"/>
    </resultMap>

    <select id="selectByFileMd5" resultMap="BaseResultMap">
        SELECT * FROM file_chunk_record 
        WHERE file_md5 = #{fileMd5}
        ORDER BY chunk_index ASC
    </select>

    <delete id="deleteByFileMd5">
        DELETE FROM file_chunk_record 
        WHERE file_md5 = #{fileMd5}
    </delete>

</mapper>
