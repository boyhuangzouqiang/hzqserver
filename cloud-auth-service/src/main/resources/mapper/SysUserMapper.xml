<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hzqserver.auth.mapper.SysUserMapper">

    <select id="selectByUsername" parameterType="string" resultType="com.hzqserver.auth.entity.SysUser">
        SELECT * FROM sys_user WHERE username = #{username}
    </select>

    <select id="selectByEmail" parameterType="string" resultType="com.hzqserver.auth.entity.SysUser">
        SELECT * FROM sys_user WHERE email = #{email}
    </select>

    <select id="selectByPhone" parameterType="string" resultType="com.hzqserver.auth.entity.SysUser">
        SELECT * FROM sys_user WHERE phone = #{phone}
    </select>

</mapper>